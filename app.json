{
  "expo": {
    "name": "TrashLife",
    "slug": "trashlife",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trashlife.app"
    },
    "android": {
      "package": "com.trashlife.app"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "TrashLife needs camera access to scan trash.",
          "enableFrameProcessors": true
        }
      ],
      "expo-dev-client"
    ]
  }
}
